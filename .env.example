# ============================================================
# SCADA HMI — Variables de Entorno
# ============================================================
# Copia este archivo a .env y rellena los valores reales.
# El archivo .env está en .gitignore y nunca debe commitearse.
#
#   cp .env.example .env
#   nano .env
#
# IMPORTANTE: Las variables NEXT_PUBLIC_* se hornean (bake) en
# el bundle de JavaScript en tiempo de BUILD, no de runtime.
# Si cambias un valor debes reconstruir la imagen:
#   docker compose build --no-cache
# ============================================================

# ── Backend API ───────────────────────────────────────────────────────────────
# URL del backend FastAPI (accesible desde el navegador del cliente).
# En producción suele ser la IP/dominio del servidor + puerto.
NEXT_PUBLIC_API_URL=http://localhost:8888

# ── MQTT Broker (WebSocket) ───────────────────────────────────────────────────
# URL completa con protocolo: ws:// (sin TLS) o wss:// (con TLS).
# Puerto 9001: WS sin TLS (típico en Mosquitto local)
# Puerto 8083/8084: WS con TLS (típico en brokers en la nube)
NEXT_PUBLIC_MQTT_WS_URL=wss://your-broker.example.com:8083

# Credenciales de acceso al broker MQTT (usuario con permisos solo de lectura
# para el HMI — separado del usuario de escritura del backend).
NEXT_PUBLIC_MQTT_USERNAME=your_mqtt_user
NEXT_PUBLIC_MQTT_PASSWORD=your_mqtt_password

# ── Puerto del contenedor frontend ───────────────────────────────────────────
# Puerto del host en el que se expone el HMI (default: 3000)
FRONTEND_PORT=3000
